{
  "name": "unraid-mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server for observing and controlling an Unraid server via its GraphQL API",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "unraid",
    "graphql",
    "homelab"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/unraid-mcp-server.d.ts",
  "bin": {
    "unraid-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist temp *.tsbuildinfo",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:types": "tsd",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:check": "graphql-codegen --config codegen.ts && git diff --exit-code src/unraid/generated.ts",
    "api:check": "api-extractor run --verbose",
    "api:update": "api-extractor run --local --verbose",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "graphql": "^16.14.0",
    "graphql-request": "^7.4.0",
    "express": "^5.2.1",
    "undici": "^7.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.1",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-graphql-request": "^7.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.3",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "tsd": "^0.33.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.32.1"
}
