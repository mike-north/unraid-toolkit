{
  "name": "unraid-cli-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for the unraid-cli toolkit: a core SDK with thin CLI and MCP wrappers over the Unraid GraphQL API",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo",
    "build": "tsc --build",
    "build:clean": "tsc --build --clean && tsc --build",
    "typecheck": "tsc --build",
    "lint": "eslint packages/*/src",
    "lint:fix": "eslint packages/*/src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r run test",
    "knip": "knip",
    "syncpack:check": "syncpack lint",
    "syncpack:fix": "syncpack fix-mismatches",
    "check": "pnpm run build && pnpm run lint && pnpm run format:check && pnpm run syncpack:check && pnpm run knip && pnpm run test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "knip": "^5.66.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.3",
    "syncpack": "^14.0.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.32.1"
}
