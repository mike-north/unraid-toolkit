# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Marketplace dist bundles are generated by `aipm build` and must be committed
# (CI freshness-checks them); re-include them despite the `dist/` rule above.
!agent-plugins/dist/
!agent-plugins/dist/**

# Git worktrees
.worktrees/

# API Extractor intermediates
temp/

# Test / coverage
coverage/

# Logs
*.log

# Scratch / temporary artifacts
scratch/

# Env & secrets
.env
*.local.*

# OS
.DS_Store

# Claude Code local configuration (auto-added)
.claude/*.local.*
